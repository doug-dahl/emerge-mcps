# Base64-encoded JSON of the `enrollment-clip-uploader` service account key.
# Same secret as `DRIVE_SA_KEY` in Google Secret Manager — the SA is already
# a Manager on the "Student Interviews" shared drive, no extra Drive setup
# needed. Raw JSON (un-encoded) is also accepted for local dev convenience.
#
# To pull from GCP and paste into Railway:
#   gcloud secrets versions access latest --secret=DRIVE_SA_KEY --project=<project-id>
DRIVE_SA_KEY=

# Shared Drive ID for "Student Interviews".
STUDENT_INTERVIEWS_DRIVE_ID=0AIgasummO4n6Uk9PVA

# Public base URL of this server (Railway-assigned). Used to construct /downloads URLs.
DOWNLOAD_BASE_URL=https://clip-editor.up.railway.app

# Optional — defaults are fine for most cases.
# DOWNLOAD_TTL_HOURS=24
# TEMP_DIR=/tmp/clip-editor
# LOG_LEVEL=INFO
# PORT=8000  # Railway sets this automatically
# ALLOWED_HOSTS=clip-editor.up.railway.app,shimmering-...up.railway.app
#   Comma-separated allowlist for FastMCP's DNS-rebinding Host-header check.
#   When unset, the check is disabled — fine for a public Railway deployment
#   since DNS rebinding only matters for localhost services.
